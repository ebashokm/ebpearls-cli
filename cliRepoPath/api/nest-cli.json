            "include": "i18n/**/*",
            "watchAssets": true,
            "outDir": "dist/apps/cron"
          }
        ]
      }
    },
    "cms-api": {
      "type": "application",
      "root": "apps/cms-api",
      "entryFile": "main",
      "sourceRoot": "apps/cms-api/src",
      "compilerOptions": {
