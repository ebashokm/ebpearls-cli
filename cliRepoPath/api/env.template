# Environment Configuration Template
# Copy this file to .env and fill in the actual values
# NEVER commit the actual .env file to version control

# Application Configuration
PORT=3000
APP_ENV=development
NODE_ENV=development

# Database Configuration
DB_CONNECTION_STRING=mongodb://localhost:27017/ebthemes

# JWT Configuration (Generate strong secrets with at least 32 characters)
JWT_ACCESS_TOKEN_SECRET=your-super-secure-access-token-secret-here-min-32-chars
JWT_ACCESS_TOKEN_EXPIRE_IN=15m
JWT_REFRESH_TOKEN_SECRET=your-super-secure-refresh-token-secret-here-min-32-chars
JWT_REFRESH_TOKEN_EXPIRE_IN=7d
JWT_BIOMETRIC_TOKEN_SECRET=your-super-secure-biometric-token-secret-here-min-32-chars
JWT_BIOMETRIC_TOKEN_EXPIRE_IN=30d

# Social Authentication
FACEBOOK_APP_SECRET=your-facebook-app-secret
GOOGLE_CLIENT_ID=your-google-client-id
APPLE_CLIENT_ID=your-apple-client-id
ANDROID_SCHEME=your-android-scheme

# AWS Configuration
S3_BUCKET_NAME=your-s3-bucket-name
S3_REGION=us-east-1
AWS_SES_ACCESS_KEY=your-aws-ses-access-key
AWS_SES_SECRET_KEY=your-aws-ses-secret-key
AWS_SES_REGION=us-east-1
AWS_SES_API_VERSION=2010-12-01
AWS_SES_FROM=noreply@yourdomain.com

# Stripe Configuration
STRIPE_SECRET=sk_test_your-stripe-secret-key
STRIPE_API_VERSION=2024-06-20
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-min-32-chars
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your-stripe-connect-webhook-secret-min-32-chars
STRIPE_CURRENCY=aud

# In-App Purchase Configuration
ANDROID_IAP_CLIENT_EMAIL=your-android-iap-client-email
ANDROID_IAP_PRIVATE_KEY=your-android-iap-private-key
IN_APP_IOS_SECRET=your-ios-in-app-secret
IAP_MODE=sandbox

# OTP Configuration
OTP_AWS_SNS_ACCESS_KEY=your-aws-sns-access-key
OTP_AWS_SNS_SECRET_KEY=your-aws-sns-secret-key
OTP_AWS_SNS_REGION=us-east-1
OTP_AWS_SNS_API_VERSION=2010-03-31
OTP_TWILIO_ACCOUNT_SID=your-twilio-account-sid
OTP_TWILIO_AUTH_TOKEN=your-twilio-auth-token
OTP_TWILIO_PHONE_NUMBER=your-twilio-phone-number

# TikTok Configuration
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# CometChat Configuration
COMET_CHAT_APP_ID=your-cometchat-app-id
COMET_CHAT_SECRET_KEY=your-cometchat-secret-key
COMET_CHAT_API_URL=https://api.cometchat.com/v2.0

# Agora Configuration
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate
AGORA_CHAT_HOST=your-agora-chat-host
AGORA_CHAT_ORG_NAME=your-agora-org-name
AGORA_CHAT_APP_NAME=your-agora-app-name

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Security Configuration
CRON_SECRET_KEY=your-cron-secret-key-min-32-chars
BULL_BOARD_PATH=/admin/queues
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=your-bull-board-password-min-8-chars

# File Upload Configuration
MULTER_UPLOAD_DEST=./uploads

# Logging Configuration
LOG_LEVEL=info

# New Relic Configuration
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your-session-secret-min-32-chars
SESSION_MAX_AGE=86400000

# CORS Configuration
CORS_ORIGINS=http://localhost:3001,https://dev-et-web.draftserver.com,https://stage-et-web.draftserver.com

# Encryption Configuration
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# API Keys and Secrets
RAPID_ID_ACCESS_TOKEN=your-rapid-id-access-token
RAPID_ID_ENVIRONMENT=sandbox

# Subscription Configuration
SUBSCRIPTION_KEY_IDENTIFIER=your-subscription-key-identifier
SUBSCRIPTION_PRIVATE_KEY=your-subscription-private-key

# Sentry
SENTRY_DSN=your-sentry-dsn