{
  "name": "nest-ebtheme",
  "version": "0.0.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "test:graphql": "k6 run --out json=load-test/results.json load-test/graphql-load-test.js",
    "test:rest": "k6 run --out json=load-test/results.json load-test/rest-load-test.js",
    "build:api": "rimraf dist/api && nest build api",
    "build:cms-api": "rimraf dist/cms-api && nest build cms-api",
    "build:cron": "rimraf dist/cron && nest build cron",
    "build:all": "npm run build:api && npm run build:cms-api && npm run build:cron",
    "docs:api": "compodoc -p apps/api/tsconfig.app.json -d docs/api",
    "docs:cms-api": "compodoc -p apps/cms-api/tsconfig.app.json -d docs/cms-api",
    "docs:combined": "compodoc -p tsconfig.json -d docs/combined",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start --exec 'node -r newrelic'",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/nest-ebtheme/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/nest-ebtheme/test/jest-e2e.json",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {if (e.code !== 'MODULE_NOT_FOUND') throw e}\"",
    "precommit": "lint-staged"
  },
  "lint-staged": {
    "**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-chime-sdk-meetings": "^3.956.0",
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/client-sqs": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.956.0",
    "@bull-board/api": "^6.16.1",
    "@bull-board/express": "^6.16.1",
    "@bull-board/nestjs": "^6.16.1",
    "@elastic/elasticsearch": "^8.14.0",
    "@faker-js/faker": "^10.1.0",
    "@keyv/redis": "^5.1.5",
    "@nestjs-cls/transactional": "^3.1.2",
    "@nestjs-cls/transactional-adapter-mongoose": "^1.1.26",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/elasticsearch": "^11.1.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/throttler": "^6.5.0",
    "@parse/node-apn": "^7.0.1",
    "@paypal/paypal-server-sdk": "^2.1.0",
    "@sentry/nestjs": "^10.29.0",
    "agora-token": "^2.0.5",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dataloader": "^2.2.3",
    "dotenv": "^17.2.3",
    "eventsource": "^4.1.0",
    "firebase-admin": "^13.6.0",
    "graphql": "^16.12.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-type-json": "^0.3.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "hi-base32": "^0.5.1",
    "i18n": "^0.15.3",
    "in-app-purchase": "github:9996rojit/in-app-purchase-v2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "moment-timezone": "^0.6.0",
    "mongoose": "^8.5.2",
    "multer": "^2.0.2",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.1.0",
    "nestjs-i18n": "^10.6.0",
    "newrelic": "^13.8.1",
    "nodemailer": "^7.0.12",
    "otpauth": "^9.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slug": "^11.0.1",
    "sqs-consumer": "^14.2.0",
    "stripe": "^16.2.0",
    "twilio": "^5.11.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.25",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@swc/core": "^1.15.7",
    "@types/bcrypt": "^6.0.0",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/in-app-purchase": "^1.11.4",
    "@types/jest": "30.0.0",
    "@types/multer": "^2.0.0",
    "@types/slug": "^5.0.9",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.0",
    "jest": "30.2.0",
    "k6": "^0.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "swc-loader": "^0.2.6",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@api(|/.*)$": "<rootDir>/apps/api/src/$1",
      "^@app/authentication(|/.*)$": "<rootDir>/libs/authentication/src/$1",
      "^@app/data-access(|/.*)$": "<rootDir>/libs/data-access/src/$1",
      "^@app/facebook-auth(|/.*)$": "<rootDir>/libs/facebook-auth/src/$1",
      "^@app/apple-auth(|/.*)$": "<rootDir>/libs/apple-auth/src/$1",
      "^@app/google-auth(|/.*)$": "<rootDir>/libs/google-auth/src/$1",
      "^@app/social-auth(|/.*)$": "<rootDir>/libs/social-auth/src/$1",
      "^@app/otp(|/.*)$": "<rootDir>/libs/otp/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/app/common/$1",
      "^@app/stripe(|/.*)$": "<rootDir>/libs/stripe/$1",
      "^@app/tiktok-auth(|/.*)$": "<rootDir>/libs/tiktok-auth/src/$1",
      "^@app/email(|/.*)$": "<rootDir>/libs/email/src/$1",
      "^@app/elastic-search(|/.*)$": "<rootDir>/libs/elastic-search/src/$1",
      "^@app/paypal-core(|/.*)$": "<rootDir>/libs/paypal-core/src/$1"
    }
  }
}
